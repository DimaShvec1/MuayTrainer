<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MuayThaiTrainer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/muay_red</item>
        <item name="colorPrimaryVariant">@color/muay_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/muay_gold</item>
        <item name="colorSecondaryVariant">@color/muay_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/muay_dark</item>
        <item name="android:windowBackground">@drawable/gradient_background</item>
    </style>

    <!-- ГРАДИЕНТНЫЕ КНОПКИ -->
    <style name="MuayButtonRed" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_gradient_red</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:elevation">8dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="MuayButtonGold" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_gradient_gold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:elevation">8dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- КАРТОЧКИ -->
    <style name="MuayCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">#33222222</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/muay_red</item>
    </style>

    <!-- ЗАГОЛОВКИ -->
    <style name="MuayTitle">
        <item name="android:textColor">@color/muay_red</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:shadowColor">#66D32F2F</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">15</item>
    </style>
</resources>